# UP2CLOUD Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!
# ════════════════════════════════════════════════════════════════════════════

# Groq AI API Key
# Get your free key at: https://console.groq.com
# Free tier: 14,400 requests per day · Llama 3.1 8B Instant
GROQ_API_KEY=sk_your_groq_api_key_here

# FormSubmit.co Endpoint
# Sign up at: https://formsubmit.co
# Replace with your unique form endpoint
FORM_ENDPOINT=https://formsubmit.co/ajax/your-email@example.com

# Node.js Server Port (optional, defaults to 3000)
PORT=3000

# ── Newsletter / Blog engagement (Cloudflare Pages env vars) ─────────────────
# Set these in: Cloudflare Pages → up2cloud-tech → Settings → Environment Variables

# Brevo (formerly Sendinblue) API key
# Get your free key at: https://app.brevo.com → My Account → SMTP & API → API Keys
# Free tier: 300 emails/day, unlimited contacts
BREVO_API_KEY=xkeysib-your-brevo-api-key-here

# Brevo contact list ID (integer)
# Create a list at: Brevo → Contacts → Lists → Create a list
# Find the ID in the list URL: /contacts/lists/2 → BREVO_LIST_ID=2
BREVO_LIST_ID=2

# Brevo verified sender email (must be verified in Brevo dashboard)
BREVO_SENDER_EMAIL=cesar@up2cloud.tech

# ── GitHub Actions secrets (Settings → Secrets and variables → Actions) ──────
# BREVO_API_KEY     — same key as above
# BREVO_LIST_ID     — same list ID as above
# BREVO_SENDER_EMAIL — same verified sender email

# ── Cloudflare KV namespace IDs ───────────────────────────────────────────────
# Created in: Cloudflare → Workers & Pages → KV → Create namespace
# Bound in:   Pages → up2cloud-tech → Settings → Functions → KV namespace bindings
#   Binding name: UP2CLOUD_COMMENTS  → namespace: up2cloud-comments
#   Binding name: UP2CLOUD_LIKES     → namespace: up2cloud-likes

# ════════════════════════════════════════════════════════════════════════════
# SECURITY REMINDERS:
# ════════════════════════════════════════════════════════════════════════════
# ✗ DO NOT hardcode secrets in HTML or JavaScript
# ✗ DO NOT commit .env to GitHub
# ✓ DO use environment variables for all secrets
# ✓ DO rotate keys if they're ever exposed
# ✓ DO add .env to .gitignore (already done)
# ════════════════════════════════════════════════════════════════════════════
