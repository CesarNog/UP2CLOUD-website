# UP2CLOUD Environment Variables
# ════════════════════════════════════════════════════════════════════════════
# Copy this file to .env and fill in your values.
# IMPORTANT: Never commit .env to version control!
# ════════════════════════════════════════════════════════════════════════════

# Groq AI API Key
# Get your free key at: https://console.groq.com
# Free tier: 14,400 requests per day · Llama 3.1 8B Instant
GROQ_API_KEY=sk_your_groq_api_key_here

# FormSubmit.co Endpoint
# Sign up at: https://formsubmit.co
# Replace with your unique form endpoint
FORM_ENDPOINT=https://formsubmit.co/ajax/your-email@example.com

# Node.js Server Port (optional, defaults to 3000)
PORT=3000

# ════════════════════════════════════════════════════════════════════════════
# SECURITY REMINDERS:
# ════════════════════════════════════════════════════════════════════════════
# ✗ DO NOT hardcode secrets in HTML or JavaScript
# ✗ DO NOT commit .env to GitHub
# ✓ DO use environment variables for all secrets
# ✓ DO rotate keys if they're ever exposed
# ✓ DO add .env to .gitignore (already done)
# ════════════════════════════════════════════════════════════════════════════
